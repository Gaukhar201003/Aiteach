rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Admin check - based on the user email provided in the log
    function isAdmin() { return isVerified() && request.auth.token.email == "gauhartoktamys1@gmail.com"; }

    // Validation Blueprint for User
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string &&
             data.role in ['teacher', 'admin'] &&
             data.competencyLevel in ['Beginner', 'Explorer', 'Practitioner', 'Integrator', 'Advanced'] &&
             data.points is int &&
             data.completedTasksCount is int &&
             data.createdAt is string &&
             data.stats is map;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && (
        isAdmin() || (
          isValidUser(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'competencyLevel', 'points', 'completedTasksCount', 'stats', 'updatedAt']) &&
          incoming().uid == existing().uid &&
          incoming().email == existing().email &&
          incoming().role == existing().role
        )
      );
      
      match /taskProgress/{taskId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /lessonPlans/{planId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /generatedTasks/{taskId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /prompts/{promptId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
  }
}
